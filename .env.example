# Copier ce fichier en .env.local et remplir les valeurs.
# .env.local est ignoré par git : AUCUNE clé ne doit être committée.

# --- Supabase (obligatoire pour l'auth et la persistance) ---
# Utiliser la clé "Publishable" (sb_publishable_…), pas la legacy anon key.
# Ne JAMAIS mettre la service_role key, la clé sb_secret ni le JWT secret ici.
VITE_SUPABASE_URL=https://votre-projet.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# --- EODHD (optionnel : sans clé, l'app utilise les données mock) ---
# Laisser vide pour forcer le mode mock.
VITE_EODHD_API_KEY=

# --- Finnhub (optionnel : analyse — consensus, objectifs, news, fondamentaux) ---
# Sans clé, la section Analyse utilise des données mock. Clé gratuite : finnhub.io
VITE_FINNHUB_API_KEY=

# --- FMP (optionnel : provider de FALLBACK, marché + analyse) ---
# Utilisé seulement si EODHD/Finnhub ne renvoient rien. Sans clé, FMP est désactivé.
# Clé gratuite : site.financialmodelingprep.com
VITE_FMP_API_KEY=

# --- Benchmark MSCI World par défaut (symbole EODHD) ---
VITE_DEFAULT_BENCHMARK=CW8.PA

# --- Login mono-utilisateur (optionnel) ---
# Si renseigné, la page de login ne demande que le mot de passe (email pré-rempli).
# Laisser vide pour afficher aussi le champ email.
VITE_LOGIN_EMAIL=

# --- Base URL pour le build (optionnel) ---
# Par défaut '/patrimoine-dashboard/' (voir vite.config.ts).
# En local vous pouvez mettre '/'.
# VITE_BASE=/
